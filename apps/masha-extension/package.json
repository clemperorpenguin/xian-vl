{
  "name": "masha-extension",
  "version": "1.0.0",
  "description": "MASHA - Multilingual Access & Site Handling Assistant",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "compile": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.33",
    "autoprefixer": "^10.4.17"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "typescript": "^5.3.3",
    "wxt": "^0.20.26"
  },
  "overrides": {
    "tmp": "^0.2.6",
    "uuid": "^11.1.1",
    "shell-quote": "^1.8.2",
    "esbuild": "^0.28.1"
  }
}
