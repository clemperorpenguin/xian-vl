{
  "manifest_version": 3,
  "name": "MASHA - Multilingual Access & Site Handling Assistant",
  "version": "1.0.0",
  "description": "Real-time screen text translation powered by Lemonade Server",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://localhost:13305/*"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
